{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Inventory items for Hair with Flair",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "minStock": { "type": "number" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "stock"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Client database",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "totalSpent": { "type": "number" },
        "lastVisit": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Sales transactions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["items", "total", "timestamp"]
    },
    "LayBy": {
      "title": "Lay-by",
      "description": "Lay-by agreements",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "paidAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "completed", "cancelled"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "payments": { "type": "array" }
      },
      "required": ["customerId", "totalAmount", "paidAmount", "status"]
    },
    "ZRAPayment": {
      "title": "ZRA Payment",
      "description": "Tax payment records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "reference": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "reference", "timestamp"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Inventory suppliers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "contactPerson": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "categories": { "type": "array" },
        "documents": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "RFQ": {
      "title": "RFQ",
      "description": "Request for Quotation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "supplierId": { "type": "string" },
        "items": { "type": "array" },
        "status": { "type": "string", "enum": ["pending", "responded"] },
        "dateIssued": { "type": "string", "format": "date-time" }
      },
      "required": ["supplierId", "items", "status", "dateIssued"]
    },
    "Quotation": {
      "title": "Quotation",
      "description": "Supplier quotations",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "rfqId": { "type": "string" },
        "supplierId": { "type": "string" },
        "items": { "type": "array" },
        "totalPrice": { "type": "number" },
        "validUntil": { "type": "string", "format": "date-time" },
        "documentUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] }
      },
      "required": ["supplierId", "totalPrice", "status"]
    },
    "Order": {
      "title": "Order",
      "description": "Procurement orders",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "quotationId": { "type": "string" },
        "supplierId": { "type": "string" },
        "items": { "type": "array" },
        "paymentTerms": { "type": "string" },
        "deliveryDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "received"] },
        "stockUpdated": { "type": "boolean" }
      },
      "required": ["supplierId", "status"]
    },
    "PriceAdjustment": {
      "title": "Price Adjustment",
      "description": "Cost breakdown and selling price calculations",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "buyingCost": { "type": "number" },
        "shippingCost": { "type": "number" },
        "logisticsCost": { "type": "number" },
        "baseCost": { "type": "number" },
        "markup": { "type": "number" },
        "finalPrice": { "type": "number" },
        "currency": { "type": "string" },
        "exchangeRate": { "type": "number" }
      },
      "required": ["orderId", "finalPrice"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Collection of customers"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Collection of sales"
    },
    "/laybys/{laybyId}": {
      "schema": "LayBy",
      "description": "Collection of lay-bys"
    },
    "/zra_payments/{paymentId}": {
      "schema": "ZRAPayment",
      "description": "Collection of ZRA payments"
    },
    "/suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "Collection of suppliers"
    },
    "/rfqs/{rfqId}": {
      "schema": "RFQ",
      "description": "Collection of RFQs"
    },
    "/quotations/{quotationId}": {
      "schema": "Quotation",
      "description": "Collection of quotations"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of orders"
    },
    "/price_adjustments/{adjustmentId}": {
      "schema": "PriceAdjustment",
      "description": "Collection of price adjustments"
    }
  }
}
